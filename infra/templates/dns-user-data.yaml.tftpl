#cloud-config

hostname: ${hostname}
manage_resolv_conf: false
manage_etc_hosts: true

apt: 
  preserve_sources_list: true
  conf: |
    Acquire {
      Check-Date "false";
    };

timezone: Europe/Amsterdam

users:
  - name: ${provision_user}
    groups: [sudo]
    shell: /bin/bash
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    ssh_authorized_keys:
      - ${ssh_public_key}

enable_ssh: true
ssh_pwauth: false
